# Cache policy:
#   - HTML and JSON refresh daily; revalidate after 1 hour.
#   - General images (favicons, OG cards, fonts): 1-day cache.
#   - Thumbnails under og/thumb/* are content-addressed by slug and only
#     regenerate when the source photo changes — 30-day cache + immutable
#     hint. Saves repeat-visitor bandwidth + improves perceived load.
<IfModule mod_headers.c>
    <FilesMatch "\.(html|json)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(svg|png|jpg|jpeg|webp|ico|woff2?)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>
<IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/og/thumb/" LONG_CACHE
</IfModule>
<IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=2592000, immutable" env=LONG_CACHE
</IfModule>

RewriteEngine On

# Canonicalize www → non-www. Every generated page already has a
# <link rel="canonical"> pointing at the bare-domain version, so this
# 301 makes the HTTP-level URL match the canonical declaration and
# stops Google from flagging www pages as soft-redirects.
RewriteCond %{HTTP_HOST} ^www\.nowservingto\.com$ [NC]
RewriteRule ^(.*)$ https://nowservingto.com/$1 [R=301,L]

# SEO landing pages: /cuisine/{key} → cuisine/{key}.html when present.
# No fallback to /index.html for unknown keys — Apache returns a real 404,
# which Google de-indexes cleanly. The old fallback made every typo or
# stale URL look like a duplicate of the homepage in GSC, and pages that
# don't generate (e.g. cuisine keys with zero entries like african_horn
# after the parent-country collapse) silently served the homepage.
RewriteCond %{DOCUMENT_ROOT}/cuisine/$1.html -f
RewriteRule ^cuisine/([a-z_]+)/?$ /cuisine/$1.html [L]

# /usage → usage.html (one-pager showing per-provider API spend)
RewriteRule ^usage/?$ /usage.html [L]

# /contribute → contribute.html (Tally form for tips + corrections)
RewriteRule ^contribute/?$ /contribute.html [L]

# Per-district SEO landing pages: /district/{slug} → district/{slug}.html
RewriteCond %{DOCUMENT_ROOT}/district/$1.html -f
RewriteRule ^district/([a-z-]+)/?$ /district/$1.html [L]

# Per-listing share links: /r/{slug} → r/{slug}.html when present
# (pre-rendered with per-listing title/og:image so X / FB / iMessage
# auto-card the personalized image and route the click to the listing
# page). No fallback to /index.html — a dropped/old slug must 404 so
# Google de-indexes it instead of treating it as a homepage duplicate.
RewriteCond %{DOCUMENT_ROOT}/r/$1.html -f
RewriteRule ^r/([\w-]+)/?$ /r/$1.html [L]
