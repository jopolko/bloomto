# Python venv + bytecode — never committed
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ETL caches (re-downloadable from Toronto Open Data on next ETL run)
tools/cache/
cache/

# Legacy BloomTO ETL outputs (kept under legacy/bloomto/data when the
# archived ETL is ever re-run; never appropriate for git history).
legacy/bloomto/data/parcels.geojson
legacy/bloomto/data/parcels-top.json
legacy/bloomto/data/parcels-broader.json
legacy/bloomto/audit/*.PRE.md

# DemoCalcTO ETL outputs (large or regenerable per rebuild)
data/democalc-permits-raw.json
data/democalc-aggregates.json
data/*.geojson

# Editor / OS scrap
*.swp
*.swo
.DS_Store
Thumbs.db

# Build/run logs
/tmp/bloomto-rebuild.log
/tmp/democalcto-rebuild*.log
*.log

# Cron-runtime artifacts
tools/.signals.lock
tools/logs/

# Local Claude Code state — per-machine, not for sharing
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Secrets — defensive guard. The real secrets file lives at
# /var/secrets/bloomto.env on prod (outside this tree), but if anyone ever
# drops a *.env file IN the repo it should never get committed.
.env
*.env
